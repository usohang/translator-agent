# ── Google Gemini API (무료 티어 사용 가능) ──────────────
# 발급: https://aistudio.google.com → Get API key
GOOGLE_API_KEY=여기에_API_키_입력

# ── 모델 선택 ─────────────────────────────────────────────
GEMINI_MODEL_PRIMARY=gemini-1.5-flash
GEMINI_MODEL_LIGHT=gemini-1.5-flash

# ── 파일 경로 ─────────────────────────────────────────────
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
IMAGES_DIR=uploads/images

# ── 제한 ──────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
TRANSLATION_BATCH_SIZE=5
MAX_CONTEXT_BLOCKS=3
