# ── Claude API ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxx

# ── 모델 선택 (기본값 그대로 사용 가능) ──────────────────
CLAUDE_MODEL_PRIMARY=claude-sonnet-4-6
CLAUDE_MODEL_LIGHT=claude-haiku-4-5-20251001

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 파일 경로 ─────────────────────────────────────────────
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
IMAGES_DIR=uploads/images

# ── 제한 ──────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
TRANSLATION_BATCH_SIZE=5
MAX_CONTEXT_BLOCKS=3
